{
  "name": "damia",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "TLoD action-RPG isometric web game",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@pixi/layout": "^3.2.0",
    "@pixi/tilemap": "^5.0.0",
    "easystarjs": "^0.4.4",
    "howler": "^2.2.4",
    "i18next": "^24.0.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "pixi-viewport": "^6.0.0",
    "pixi.js": "^8.6.0",
    "yoga-layout": "^3.2.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/easystarjs": "^0.3.4",
    "@types/howler": "^2.2.12",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.13.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^5.1.0",
    "vitest": "^2.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
